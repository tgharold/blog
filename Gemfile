# Skinny Bones Gemfile
source "https://rubygems.org"

# Use Jekyll 4.3.4
gem "jekyll", "~> 4.4.1"
gem "jekyll-sitemap", "~> 1.4"
gem "jekyll-gist", "~> 1.5"
gem "jekyll-feed", "~> 0.17"

# Ruby 4.0 compatibility: csv was removed from default gems
gem "csv", "~> 3.3"

# Ruby 4.0 compatibility: yaml was removed from default gems
gem "yaml", "~> 0.4"

# Ruby 4.0 compatibility: psych was removed from default gems
gem "psych", "~> 5.1"

# Ruby 4.0 compatibility: base64 was removed from default gems
gem "base64", "~> 0.3"

# Ruby 3.4+ compatibility: bigdecimal was removed from default gems
gem "bigdecimal", "~> 3.1"

# Bourbon and Neat CSS frameworks
gem 'bourbon', '~> 6.0'
gem 'neat', '~> 2.0'

# Remove the github-pages gem from the main dependencies and add it only to the build group
# This avoids conflicts with GitHub Pages' automatic gem selection

# Possible gems to use later
# gem 'jekyll-archives'
