{
  "$schema": "https://opencode.ai/config.json",
  "model": "oMLX/Qwen3.6-35B-A3B-6bit",
  //"small_model": "mlx-community/Qwen3-Coder-30B-A3B-Instruct-MLX-6bit",
  "provider": {
    "oMLX": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:OMLX_BASE_URL}",
        "apiKey": "{env:OMLX_API_TOKEN}"
      },
      "models": {
        "Qwen3-Coder-30B-A3B-Instruct-MLX-6bit": {
          "id": "mlx-community/Qwen3-Coder-30B-A3B-Instruct-MLX-6bit",
          "reasoning": true,
          "tool_call": true
        },
        "Qwen3.5-35B-A3B-6bit": {
          "id": "mlx-community/Qwen3.5-35B-A3B-6bit",
          "reasoning": true,
          "tool_call": true
        },
        "Qwen3.6-35B-A3B-6bit": {
          "id": "mlx-community/Qwen3.6-35B-A3B-6bit",
          "reasoning": true,
          "tool_call": true
        }
      }
    }
  },
  "permission": {
    "*": "ask",
    "bash": {
      "cat *": "allow",
      "echo *": "allow",
      "find *": "allow",
      "git status": "allow",
      "ls *": "allow",
      "ls -la *": "allow",
      "pwd": "allow",
      "touch *": "allow",
      "which *": "allow",
    },
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "question": "allow",
    "read": "allow",
    "todoread": "allow",
    "todowrite": "allow",
  }
}